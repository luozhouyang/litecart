{
  "name": "litecart-api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler build",
    "deploy": "wrangler deploy --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "auth:generate": "pnpm dlx auth@latest generate --config better-auth.config.ts --output src/db/schema/auth.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "do:auth:generate": "pnpm dlx auth@latest generate --config better-auth-do.config.ts --output src/durable-objects/schema/auth.ts --yes",
    "do:generate": "drizzle-kit generate --config drizzle-do.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "@litecart/types": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "jose": "catalog:",
    "nanoid": "catalog:",
    "uuidv7": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@libsql/client": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
